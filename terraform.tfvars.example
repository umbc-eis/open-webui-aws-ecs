region                       = "us-east-1"
azs                          = ["us-east-1a", "us-east-1b"]

vpc_id                       = "vpc-xxxxxxxxxxxxxxxxx"
vpc_cidr_block               = "10.0.0.0/16"

ecs_subnet_ids  = ["subnet-xxxxxxxxxxxxxxxxx", "subnet-xxxxxxxxxxxxxxxxx"]  # private
alb_subnet_ids  = ["subnet-xxxxxxxxxxxxxxxxx", "subnet-xxxxxxxxxxxxxxxxx"]  # public

open_webui_task_cpu   = 1024
open_webui_task_mem   = 2048
open_webui_task_count = 3
open_webui_port       = 8080

# First apply: point at the upstream image so the stack (including the ECR
# repo) comes up. After the initial apply, run scripts/build-and-push.sh
# and update this URL to the ECR-hosted custom image.
#   e.g. "123456789012.dkr.ecr.us-east-1.amazonaws.com/openwebui-umbc:v0.6.18-extras1"
open_webui_image_url = "ghcr.io/open-webui/open-webui:v0.6.18"

open_webui_domain              = "openwebui.example.com"
open_webui_domain_route53_zone = "ZXXXXXXXXXXXXX"
open_webui_domain_ssl_cert_arn = "arn:aws:acm:us-east-1:123456789012:certificate/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"

# Database
db_engine_version = "15.12"  # Aurora Serverless v2 (PostgreSQL)

# Admin user (Lambda creates this on first deploy, password lands in Secrets Manager)
admin_name        = "Admin User"
admin_email       = "admin@example.com"
enable_signup     = true
default_user_role = "user"

# AWS Cognito SSO (optional)
# Set enable_oauth_signup = true and fill the cognito_* fields to enable SSO.
enable_oauth_signup           = false
oauth_provider_name           = "SSO"
cognito_user_pool_id          = ""    # e.g. "us-east-1_ABC123DEF"
cognito_app_client_id         = ""
cognito_app_client_secret     = ""
oauth_merge_accounts_by_email = true
oauth_allowed_domains         = "*"   # or restrict: "example.com"
disable_local_auth            = false # disable username/password login
force_oauth_login             = false # force all users to use OAuth/SSO

# API and connection configuration
enable_api_key            = false  # programmatic + admin API access
enable_direct_connections = true   # allow users to add their own LLM connections

# WAF (primary public-internet gate; the ALB SG itself is open on 443)
enable_waf             = true
waf_enable_logging     = false  # CloudWatch /aws/wafv2/openwebui if true
waf_log_retention_days = 7
