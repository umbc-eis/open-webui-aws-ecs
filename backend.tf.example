# Backend configuration for remote state storage
#
# INSTRUCTIONS:
# 1. First, create the S3 bucket and DynamoDB table (see bootstrap/ directory)
# 2. Copy this file to backend.tf: cp backend.tf.example backend.tf
# 3. Update the bucket name and dynamodb_table name below
# 4. Run: terraform init -migrate-state
# 5. Commit backend.tf to version control

terraform {
  backend "s3" {
    # S3 bucket for state storage (must be created first)
    bucket = "your-terraform-state-bucket-name"  # CHANGE THIS
    key    = "open-webui-fargate/terraform.tfstate"
    region = "us-east-1"  # Match your region

    # DynamoDB table for state locking (must be created first)
    dynamodb_table = "terraform-state-lock"  # CHANGE THIS if you used a different name

    # Enable encryption at rest
    encrypt = true

    # Optional: Enable versioning on the S3 bucket for state history
    # This should be configured on the S3 bucket itself
  }
}